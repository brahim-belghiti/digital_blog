---
import { type CollectionEntry, getCollection } from 'astro:content';
import PageLayout from '@layouts/PageLayout.astro';
import Container from '@components/Container.astro';
import FormattedDate from '@components/common/FormattedDate.astro';
import BackToPrev from '@components/navigation/BackToPrev.astro';
import Link from '@components/common/Link.astro';

export async function getStaticPaths() {
  const projects = (await getCollection('projects'))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: project,
  }));
}
type Props = CollectionEntry<'projects'>;

const project = Astro.props;
const { Content } = await project.render();
---

<PageLayout title={project.data.title} description={project.data.description}>
  <Container>
    <div class="animate">
      <BackToPrev href="/projects"> Back to projects </BackToPrev>
    </div>
    {project.data.image && (
      <div class="animate my-8 overflow-hidden rounded-xl aspect-video">
        <img
          src={project.data.image}
          alt={project.data.title}
          class="w-full h-full object-cover"
        />
      </div>
    )}

    <div class="space-y-3 my-10">
      <div class="animate flex items-center gap-2 flex-wrap">
        <div class="text-sm text-gray-500 dark:text-gray-400">
          <FormattedDate date={project.data.date} />
        </div>
        <span class="text-gray-300 dark:text-gray-600">&bull;</span>
        <span class={`text-xs px-2.5 py-1 rounded-full font-medium ${
          project.data.category === 'opensource'
            ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400'
            : project.data.category === 'personal'
            ? 'bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400'
            : 'bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400'
        }`}>
          {project.data.category === 'opensource' ? 'Open Source' : project.data.category === 'personal' ? 'Personal' : 'Client Work'}
        </span>
      </div>
      <h1 class="animate text-3xl md:text-4xl font-bold text-black dark:text-white">
        {project.data.title}
      </h1>
      {
        (project.data.demoURL || project.data.repoURL) && (
          <nav class="animate flex gap-2 items-center text-base text-gray-500 dark:text-gray-400">
            {project.data.demoURL && (
              <Link href={project.data.demoURL} external style="font-medium">
                Live demo →
              </Link>
            )}
            {project.data.demoURL && project.data.repoURL && <span class="text-gray-300 dark:text-gray-600">/</span>}
            {project.data.repoURL && (
              <Link href={project.data.repoURL} external style="font-medium">
                Source code →
              </Link>
            )}
          </nav>
        )
      }
    </div>
    <article class="animate">
      <Content />
    </article>
  </Container>
</PageLayout>
