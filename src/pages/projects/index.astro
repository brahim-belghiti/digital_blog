---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import { PROJECTS } from "@consts";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const clientProjects = projects.filter((p) => p.data.category === "client");
const openSourceProjects = projects.filter(
  (p) => p.data.category === "opensource" || p.data.category === "personal",
);

// Unique stacks present in actual projects
const availableStacks = [...new Set(projects.map((p) => p.data.stack))].sort();

// Unique tech tags across all projects, sorted
const allTechTags = [
  ...new Set(
    projects.flatMap((p) => (p.data.tags ?? []).filter(Boolean) as string[]),
  ),
].sort();
---

<PageLayout title={PROJECTS.TITLE} description={PROJECTS.DESCRIPTION}>
  <Container>
    <div class="pt-8 pb-8">
      <h1
        class="animate font-bold text-4xl md:text-5xl text-black dark:text-white mb-3 tracking-tight"
      >
        Projects
      </h1>
      <p class="text-base max-w-2xl text-gray-500 dark:text-gray-400">
        {PROJECTS.DESCRIPTION}
      </p>
    </div>

    <!-- Two-row filter -->
    <div class="space-y-3 mb-10" id="filter-bar">
      <!-- Stack row -->
      <div class="flex flex-wrap items-center gap-2">
        <span class="filter-label">Stack</span>
        <button class="filter-pill stack-pill active" data-stack="all"
          >All</button
        >
        {
          availableStacks.map((stack) => (
            <button class="filter-pill stack-pill" data-stack={stack}>
              {stack.charAt(0).toUpperCase() + stack.slice(1)}
            </button>
          ))
        }
      </div>

      <!-- Tech row -->
      <div class="flex flex-wrap items-center gap-2">
        <span class="filter-label">Tech</span>
        <button class="filter-pill tech-pill active" data-tech="all">All</button
        >
        {
          allTechTags.map((tag) => (
            <button class="filter-pill tech-pill" data-tech={tag}>
              {tag}
            </button>
          ))
        }
      </div>
    </div>

    {
      openSourceProjects.length > 0 && (
        <section class="mb-16 project-section" id="section-opensource">
          <div class="flex items-center gap-4 mb-8">
            <h2 class="text-2xl font-bold text-black dark:text-white">
              Open Source & Personal
            </h2>
            <div class="flex-1 h-px bg-gray-200 dark:bg-gray-700" />
            <span class="text-sm text-gray-500 dark:text-gray-400">
              {openSourceProjects.length} projects
            </span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
            {openSourceProjects.map((project) => (
              <div
                class="group project-card-wrapper"
                data-tags={JSON.stringify(
                  (project.data.tags ?? []).filter(Boolean),
                )}
                data-stack={project.data.stack}
              >
                <a
                  href={`/projects/${project.slug}`}
                  class="block h-full overflow-hidden rounded-xl bg-white dark:bg-gray-800 shadow-md hover:shadow-xl transition-all duration-300"
                  aria-label={`View details for ${project.data.title}`}
                >
                  <div class="relative overflow-hidden aspect-video">
                    {project.data.image ? (
                      <img
                        src={project.data.image}
                        alt={project.data.title}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    ) : (
                      <div class="w-full h-full bg-gradient-to-br from-orange-500/70 to-purple-600/70 flex items-center justify-center">
                        <span class="text-3xl font-bold text-white">
                          {project.data.title.charAt(0).toUpperCase()}
                        </span>
                      </div>
                    )}
                  </div>
                  <div class="p-6">
                    <div class="flex items-center gap-2 mb-3">
                      <h3 class="font-bold text-xl text-gray-900 dark:text-white group-hover:text-orange-600 dark:group-hover:text-orange-400 transition-colors">
                        {project.data.title}
                      </h3>
                      {project.data.repoURL && (
                        <span class="text-xs px-2 py-0.5 rounded-full border border-gray-300 dark:border-gray-600 text-gray-500 dark:text-gray-400 shrink-0">
                          open source
                        </span>
                      )}
                    </div>
                    <p class="text-gray-600 dark:text-gray-300 line-clamp-2 mb-4 text-sm">
                      {project.data.description}
                    </p>
                    {project.data.tags && (
                      <div class="flex flex-wrap gap-2 pt-3 border-t border-gray-100 dark:border-gray-700">
                        {project.data.tags.slice(0, 4).map((tag) => (
                          <span class="text-xs bg-gray-100 dark:bg-gray-700 px-2.5 py-1 rounded-full text-gray-700 dark:text-gray-300">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              </div>
            ))}
          </div>
        </section>
      )
    }

    {
      clientProjects.length > 0 && (
        <section class="mb-16 project-section" id="section-client">
          <div class="flex items-center gap-4 mb-8">
            <h2 class="text-2xl font-bold text-black dark:text-white">
              Client Work
            </h2>
            <div class="flex-1 h-px bg-gray-200 dark:bg-gray-700" />
            <span class="text-sm text-gray-500 dark:text-gray-400">
              {clientProjects.length} projects
            </span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">
            {clientProjects.map((project) => (
              <div
                class="group project-card-wrapper"
                data-tags={JSON.stringify(
                  (project.data.tags ?? []).filter(Boolean),
                )}
                data-stack={project.data.stack}
              >
                <a
                  href={`/projects/${project.slug}`}
                  class="block h-full overflow-hidden rounded-xl bg-white dark:bg-gray-800 shadow-md hover:shadow-xl transition-all duration-300"
                  aria-label={`View details for ${project.data.title}`}
                >
                  <div class="relative overflow-hidden aspect-video">
                    {project.data.image ? (
                      <img
                        src={project.data.image}
                        alt={project.data.title}
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                      />
                    ) : (
                      <div class="w-full h-full bg-gradient-to-br from-orange-500/70 to-purple-600/70 flex items-center justify-center">
                        <span class="text-3xl font-bold text-white">
                          {project.data.title.charAt(0).toUpperCase()}
                        </span>
                      </div>
                    )}
                  </div>
                  <div class="p-6">
                    <h3 class="font-bold text-xl text-gray-900 dark:text-white mb-3 group-hover:text-orange-600 dark:group-hover:text-orange-400 transition-colors">
                      {project.data.title}
                    </h3>
                    <p class="text-gray-600 dark:text-gray-300 line-clamp-2 mb-4 text-sm">
                      {project.data.description}
                    </p>
                    {project.data.tags && (
                      <div class="flex flex-wrap gap-2 pt-3 border-t border-gray-100 dark:border-gray-700">
                        {project.data.tags.slice(0, 4).map((tag) => (
                          <span class="text-xs bg-gray-100 dark:bg-gray-700 px-2.5 py-1 rounded-full text-gray-700 dark:text-gray-300">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </a>
              </div>
            ))}
          </div>
        </section>
      )
    }
  </Container>
</PageLayout>

<style>
  .filter-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: #9ca3af;
    width: 3.5rem;
    flex-shrink: 0;
  }

  .filter-pill {
    padding: 0.25rem 0.85rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    font-weight: 500;
    border: 1px solid #e5e7eb;
    color: #6b7280;
    background: transparent;
    cursor: pointer;
    transition:
      border-color 150ms,
      color 150ms,
      background 150ms;
  }
  .filter-pill:hover {
    border-color: #f97316;
    color: #f97316;
  }
  .filter-pill.active {
    background: #f97316;
    border-color: #f97316;
    color: #fff;
  }

  :global(.dark) .filter-pill {
    border-color: #374151;
    color: #9ca3af;
  }
  :global(.dark) .filter-pill:hover {
    border-color: #f97316;
    color: #f97316;
  }
  :global(.dark) .filter-pill.active {
    background: #f97316;
    border-color: #f97316;
    color: #fff;
  }
</style>

<script>
  let activeStack = "all";
  let activeTech = "all";

  const cards = document.querySelectorAll<HTMLElement>(".project-card-wrapper");
  const sections = document.querySelectorAll<HTMLElement>(".project-section");

  function applyFilters() {
    cards.forEach((card) => {
      const cardStack = card.dataset.stack ?? "";
      const cardTags: string[] = JSON.parse(card.dataset.tags ?? "[]");

      const stackOk = activeStack === "all" || cardStack === activeStack;
      const techOk = activeTech === "all" || cardTags.includes(activeTech);

      card.style.display = stackOk && techOk ? "" : "none";
    });

    sections.forEach((section) => {
      const anyVisible = [
        ...section.querySelectorAll<HTMLElement>(".project-card-wrapper"),
      ].some((c) => c.style.display !== "none");
      section.style.display = anyVisible ? "" : "none";
    });
  }

  document.querySelectorAll<HTMLButtonElement>(".stack-pill").forEach((btn) => {
    btn.addEventListener("click", () => {
      document
        .querySelectorAll(".stack-pill")
        .forEach((p) => p.classList.remove("active"));
      btn.classList.add("active");
      activeStack = btn.dataset.stack ?? "all";
      applyFilters();
    });
  });

  document.querySelectorAll<HTMLButtonElement>(".tech-pill").forEach((btn) => {
    btn.addEventListener("click", () => {
      document
        .querySelectorAll(".tech-pill")
        .forEach((p) => p.classList.remove("active"));
      btn.classList.add("active");
      activeTech = btn.dataset.tech ?? "all";
      applyFilters();
    });
  });
</script>
