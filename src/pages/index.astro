---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import ArrowCard from "@components/ArrowCard.astro";
import Link from "@components/common/Link.astro";
import { SITE, HOME, SOCIALS } from "@consts";

interface ProjectEntry {
  data: {
    title: string;
    description: string;
    date: Date;
    demoURL?: string;
    repoURL?: string;
    image?: string;
    draft?: boolean;
    tags?: string[];
    stack?: string;
    category?: string;
  };
  slug: string;
}

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_PROJECTS_ON_HOMEPAGE) as ProjectEntry[];
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <section class="mb-16 rounded-2xl overflow-hidden shadow-2xl">
      <!-- GNOME Headerbar -->
      <div
        class="bg-[#2d2d2d] flex items-center justify-between px-3 py-2 border-b border-black/30"
      >
        <!-- Left: hamburger menu -->
        <button
          class="p-1.5 rounded hover:bg-white/10 transition-colors text-gray-400 hover:text-gray-200 select-none"
          aria-hidden="true"
          tabindex="-1"
        >
          <svg width="14" height="14" viewBox="0 0 14 14" fill="currentColor">
            <rect y="1" width="14" height="1.5" rx="0.75"></rect>
            <rect y="6.25" width="14" height="1.5" rx="0.75"></rect>
            <rect y="11.5" width="14" height="1.5" rx="0.75"></rect>
          </svg>
        </button>
        <!-- Center: title -->
        <span class="text-xs text-gray-400 font-sans select-none tracking-wide">
          brahim@arch: ~
        </span>
        <!-- Right: close button -->
        <button
          class="w-6 h-6 flex items-center justify-center rounded hover:bg-white/10 transition-colors text-gray-400 hover:text-gray-200 text-sm select-none leading-none"
          aria-hidden="true"
          tabindex="-1"
        >
          ✕
        </button>
      </div>

      <!-- Terminal body -->
      <div
        class="bg-gray-950 px-6 md:px-10 py-7 font-mono text-sm md:text-base min-h-[220px]"
        id="terminal-body"
      >
        <!-- Filled by JS -->
      </div>

      <!-- CTA strip -->
      <div
        class="bg-[#2d2d2d] border-t border-gray-800 px-6 md:px-10 py-5 flex flex-wrap gap-3"
      >
        <a
          href="/projects"
          class="px-6 py-2.5 bg-orange-600 hover:bg-orange-700 text-white rounded-lg text-sm font-medium transition-all duration-200 shadow-md hover:shadow-lg hover:translate-y-[-2px]"
        >
          View Projects
        </a>
        <a
          href={`mailto:${SITE.EMAIL}`}
          class="px-6 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-200 rounded-lg text-sm font-medium border border-gray-700 transition-all duration-200 hover:translate-y-[-2px]"
        >
          Get in touch
        </a>
      </div>
    </section>

    <script>
      const TYPING_SPEED = 55;
      const JITTER = 25;

      type Line =
        | { kind: "blank" }
        | { kind: "cmd"; text: string }
        | { kind: "out"; text: string; green?: boolean };

      const sequence: Line[] = [
        { kind: "cmd", text: "whoami" },
        { kind: "out", text: "Brahim Belghiti — Fullstack Developer" },
        { kind: "blank" },
        { kind: "cmd", text: "stack" },
        {
          kind: "out",
          text: "▸ Frontend   React · Next.js · TypeScript · TailwindCSS",
        },
        { kind: "out", text: "▸ Backend    Laravel · PHP · REST APIs" },
        { kind: "blank" },
        { kind: "cmd", text: "cat open-to-work.txt" },
        {
          kind: "out",
          text: "Open to freelance & full-time opportunities ✓",
          green: true,
        },
      ];

      async function sleep(ms: number) {
        return new Promise((r) => setTimeout(r, ms));
      }

      async function run() {
        const body = document.getElementById("terminal-body");
        if (!body) return;

        const reduced = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;

        for (const step of sequence) {
          if (step.kind === "blank") {
            const el = document.createElement("div");
            el.className = "h-2";
            body.appendChild(el);
            continue;
          }

          const row = document.createElement("div");
          row.className = "flex items-start gap-2 leading-7";

          if (step.kind === "cmd") {
            const prompt = document.createElement("span");
            prompt.className = "text-green-400 select-none shrink-0";
            prompt.textContent = "$";

            const cmd = document.createElement("span");
            cmd.className = "text-white";

            const cur = document.createElement("span");
            cur.className = "terminal-cursor";

            row.appendChild(prompt);
            row.appendChild(cmd);
            row.appendChild(cur);
            body.appendChild(row);

            if (!reduced) await sleep(300);

            for (const ch of step.text) {
              cmd.textContent += ch;
              if (!reduced) await sleep(TYPING_SPEED + Math.random() * JITTER);
            }

            cur.remove();
            if (!reduced) await sleep(200);
          } else {
            row.className += step.green
              ? " text-green-400 pl-4"
              : " text-gray-400 pl-4";
            row.textContent = step.text;
            body.appendChild(row);
            if (!reduced) await sleep(60);
          }
        }

        // Final blinking cursor
        const finalRow = document.createElement("div");
        finalRow.className = "flex items-center gap-2 leading-7 mt-1";
        finalRow.innerHTML =
          '<span class="text-green-400 select-none">$</span><span class="terminal-cursor"></span>';
        body.appendChild(finalRow);
      }

      run();
    </script>

    <div class="space-y-16">
      <section class="reveal space-y-6">
        <div class="flex items-center justify-between mb-6">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-orange-500 mb-1">Writing</p>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Latest Posts</h2>
          </div>
          <Link
            href="/blog"
            style="group flex items-center gap-2 px-4 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-sm"
          >
            See all posts
            <span
              class="transform transition-transform duration-300 group-hover:translate-x-1"
              >→</span
            >
          </Link>
        </div>

        <ul class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {
            blog.map((post, index) => (
              <li
                class="fade-in-up"
                style={`animation-delay: ${index * 100}ms`}
              >
                <ArrowCard entry={post} />
              </li>
            ))
          }
        </ul>
      </section>

      <section class="reveal space-y-6" id="projects">
        <div class="flex items-center justify-between mb-6">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-orange-500 mb-1">Work</p>
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Recent Projects</h2>
          </div>
          <Link
            href="/projects"
            style="group flex items-center gap-2 px-4 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-sm"
          >
            See all projects
            <span
              class="transform transition-transform duration-300 group-hover:translate-x-1"
              >→</span
            >
          </Link>
        </div>

        {
          projects.length > 0 ? (
            <div class="space-y-6">
              {/* ── Featured card (first project) ── */}
              <div class="project-card" style="animation-delay: 0ms">
                <div class="group relative rounded-xl overflow-hidden bg-white dark:bg-gray-800 shadow-lg hover:shadow-xl transition-all duration-300">
                  <a
                    href={`/projects/${projects[0].slug}`}
                    class="absolute inset-0 z-0 rounded-xl"
                    aria-label={`View details for ${projects[0].data.title}`}
                  />
                  <div class="md:flex">
                    <div class="relative overflow-hidden aspect-video md:aspect-auto md:w-2/5 md:min-h-[260px]">
                      {projects[0].data.image ? (
                        <img
                          src={projects[0].data.image}
                          alt={projects[0].data.title}
                          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                      ) : (
                        <div class="w-full h-full bg-gradient-to-br from-orange-500/70 to-purple-600/70 flex items-center justify-center">
                          <span class="text-5xl font-bold text-white">
                            {projects[0].data.title.charAt(0).toUpperCase()}
                          </span>
                        </div>
                      )}
                    </div>
                    <div class="p-6 md:p-8 md:w-3/5 flex flex-col">
                      {projects[0].data.stack && (
                        <div class="mb-3">
                          <span
                            class="stack-badge text-xs px-2.5 py-1 rounded-full font-medium capitalize"
                            data-stack={projects[0].data.stack}
                          >
                            {projects[0].data.stack}
                          </span>
                        </div>
                      )}
                      <h3 class="font-bold text-2xl text-gray-900 dark:text-white mb-3 group-hover:text-orange-600 dark:group-hover:text-orange-400 transition-colors">
                        {projects[0].data.title}
                      </h3>
                      <p class="text-gray-600 dark:text-gray-300 text-sm line-clamp-4 mb-4 flex-1">
                        {projects[0].data.description}
                      </p>
                      {projects[0].data.tags && (
                        <div class="flex flex-wrap gap-2 mb-5">
                          {projects[0].data.tags.slice(0, 4).map((tag) => (
                            <span class="text-xs bg-gray-100 dark:bg-gray-700 px-2.5 py-1 rounded-full text-gray-700 dark:text-gray-300">
                              {tag}
                            </span>
                          ))}
                        </div>
                      )}
                      <div class="flex items-center gap-3 mt-auto">
                        {projects[0].data.demoURL && (
                          <a
                            href={projects[0].data.demoURL}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="relative z-10 text-sm px-4 py-2 rounded-lg bg-orange-600 hover:bg-orange-700 text-white transition-colors font-medium"
                          >
                            Live demo →
                          </a>
                        )}
                        <span class="text-sm text-gray-500 dark:text-gray-400 group-hover:text-orange-600 dark:group-hover:text-orange-400 transition-colors font-medium">
                          View project →
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              {/* ── Remaining projects grid ── */}
              {projects.length > 1 && (
                <ul class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                  {projects.slice(1).map((project, index) => (
                    <li
                      class="project-card"
                      style={`animation-delay: ${(index + 1) * 150}ms`}
                    >
                      <div class="group relative h-full rounded-xl overflow-hidden bg-white dark:bg-gray-800 shadow-md hover:shadow-xl transition-all duration-300">
                        <a
                          href={`/projects/${project.slug}`}
                          class="absolute inset-0 z-0 rounded-xl"
                          aria-label={`View details for ${project.data.title}`}
                        />
                        <div class="relative overflow-hidden aspect-video">
                          {project.data.image ? (
                            <img
                              src={project.data.image}
                              alt={project.data.title}
                              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                            />
                          ) : (
                            <div class="w-full h-full bg-gradient-to-br from-orange-500/70 to-purple-600/70 flex items-center justify-center">
                              <span class="text-3xl font-bold text-white">
                                {project.data.title.charAt(0).toUpperCase()}
                              </span>
                            </div>
                          )}
                        </div>
                        <div class="p-5 flex flex-col">
                          {project.data.stack && (
                            <div class="mb-2">
                              <span
                                class="stack-badge text-xs px-2 py-0.5 rounded-full font-medium capitalize"
                                data-stack={project.data.stack}
                              >
                                {project.data.stack}
                              </span>
                            </div>
                          )}
                          <h3 class="font-bold text-xl text-gray-900 dark:text-white mb-2 group-hover:text-orange-600 dark:group-hover:text-orange-400 transition-colors">
                            {project.data.title}
                          </h3>
                          <p class="text-gray-600 dark:text-gray-300 line-clamp-2 text-sm flex-1 mb-4">
                            {project.data.description}
                          </p>
                          {project.data.tags && (
                            <div class="flex flex-wrap gap-2 pt-3 border-t border-gray-100 dark:border-gray-700">
                              {project.data.tags.slice(0, 3).map((tag) => (
                                <span class="text-xs bg-gray-100 dark:bg-gray-700 px-2.5 py-1 rounded-full text-gray-700 dark:text-gray-300">
                                  {tag}
                                </span>
                              ))}
                            </div>
                          )}
                        </div>
                      </div>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ) : (
            <div class="text-center py-20 bg-gray-50 dark:bg-gray-800/50 rounded-xl">
              <p class="text-gray-600 dark:text-gray-400 text-lg">
                No projects available. Check back soon!
              </p>
            </div>
          )
        }
      </section>

      <section
        class="reveal space-y-6 rounded-2xl bg-gradient-to-br from-gray-50 to-white dark:from-gray-900 dark:to-gray-800 p-8 md:p-10"
      >
        <div class="mb-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-orange-500 mb-1">Contact</p>
          <h2 class="text-xl font-bold text-gray-900 dark:text-white">Let's Connect</h2>
        </div>

        <div class="max-w-2xl mb-8">
          <p class="text-lg text-gray-700 dark:text-gray-300">
            If you want to get in touch with me about something or just to say
            hi, reach out on social media or send me an email.
          </p>
        </div>

        <div
          class="w-full grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
        >
          {
            SOCIALS.map((SOCIAL, index) => (
              <a
                href={SOCIAL.HREF}
                target="_blank"
                rel="noopener noreferrer"
                class="social-link flex items-center gap-3 p-4 rounded-lg bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-700 transition-all duration-200 hover:shadow-md"
                style={`animation-delay: ${index * 100}ms`}
                aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}
              >
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-orange-600 dark:text-orange-400">
                  {SOCIAL.NAME.toLowerCase() === "github" && (
                    <svg
                      viewBox="0 0 24 24"
                      class="h-5 w-5"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
                    </svg>
                  )}
                  {SOCIAL.NAME.toLowerCase() === "linkedin" && (
                    <svg
                      viewBox="0 0 24 24"
                      class="h-5 w-5"
                      fill="currentColor"
                      aria-hidden="true"
                    >
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                    </svg>
                  )}
                </div>
                <span class="font-medium text-gray-900 dark:text-white capitalize">
                  {SOCIAL.NAME}
                </span>
              </a>
            ))
          }

          <a
            href={`mailto:${SITE.EMAIL}`}
            class="w-full social-link flex items-center gap-3 p-4 rounded-lg bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700 border border-gray-100 dark:border-gray-700 transition-all duration-200 hover:shadow-md"
            style={`animation-delay: ${SOCIALS.length * 100}ms`}
            aria-label={`Email ${SITE.NAME}`}
          >
            <div
              class="flex-shrink-0 w-10 h-10 rounded-full bg-orange-100 dark:bg-orange-900/30 flex items-center justify-center text-orange-600 dark:text-orange-400"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                ></path>
              </svg>
            </div>
            <span class="font-medium text-gray-900 dark:text-white break-all"
              >{SITE.EMAIL}</span
            >
          </a>
        </div>
      </section>
    </div>
  </Container>
</PageLayout>

<style>
  /* Base animations */
  .animate-fade-in-up {
    opacity: 0;
    animation: fadeInUp 0.8s ease-out forwards;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-wave {
    animation: wave 2.5s infinite;
    transform-origin: 70% 70%;
    display: inline-block;
  }

  @keyframes wave {
    0% {
      transform: rotate(0deg);
    }
    10% {
      transform: rotate(14deg);
    }
    20% {
      transform: rotate(-8deg);
    }
    30% {
      transform: rotate(14deg);
    }
    40% {
      transform: rotate(-4deg);
    }
    50% {
      transform: rotate(10deg);
    }
    60% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(0deg);
    }
  }

  /* Stack badges */
  .stack-badge[data-stack="frontend"] {
    background: #dbeafe;
    color: #1d4ed8;
  }
  .stack-badge[data-stack="fullstack"] {
    background: #ede9fe;
    color: #7c3aed;
  }
  .stack-badge[data-stack="backend"] {
    background: #dcfce7;
    color: #15803d;
  }
  :global(.dark) .stack-badge[data-stack="frontend"] {
    background: rgba(30, 58, 138, 0.35);
    color: #93c5fd;
  }
  :global(.dark) .stack-badge[data-stack="fullstack"] {
    background: rgba(88, 28, 135, 0.35);
    color: #c4b5fd;
  }
  :global(.dark) .stack-badge[data-stack="backend"] {
    background: rgba(20, 83, 45, 0.35);
    color: #86efac;
  }

  /* Project cards animation */
  .project-card {
    opacity: 0;
    transform: translateY(30px);
    animation: fadeInUp 0.8s ease-out forwards;
  }

  /* Social links animation */
  .social-link {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.6s ease-out forwards;
  }

  /* Continuous animation for background elements */
  .fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeInUp 0.7s ease-out forwards;
  }
</style>
